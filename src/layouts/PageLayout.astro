---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  pageTitle: string;
  siteTitle: string;
  siteDescription: string;
  html: string;
}

const { pageTitle, siteTitle, siteDescription, html } = Astro.props;
---

<BaseLayout title={pageTitle} siteTitle={siteTitle} siteDescription={siteDescription}>
  <article class="post">
    <header class="post-header">
      <h1 class="post-title">{pageTitle}</h1>
    </header>
    <div class="post-content" set:html={html} />
  </article>
</BaseLayout>
